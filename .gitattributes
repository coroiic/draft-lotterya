<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RHO | ULTRA-GLOW LOTTERY</title>
    <style>
        :root {
            --rho-gold: #c9a05a;
            --rho-gold-glow: rgba(201, 160, 90, 0.4);
            --neon-cyan: #00f2ff;
            --dark-bg: #030508;
            --card-bg: rgba(255, 255, 255, 0.03);
        }

        body {
            background-color: var(--dark-bg);
            color: white;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            background: radial-gradient(circle at center, #0a111a 0%, #030508 100%);
            min-height: 100vh;
            overflow-x: hidden;
        }

        header {
            background: rgba(0, 0, 0, 0.95);
            display: flex;
            align-items: center;
            padding: 15px 50px;
            border-bottom: 2px solid var(--rho-gold);
            box-shadow: 0 10px 40px rgba(0,0,0,0.9);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .rho-shield {
            background: linear-gradient(145deg, var(--rho-gold), #8a6d3b);
            color: black;
            font-weight: 900;
            padding: 15px 20px;
            font-size: 2rem;
            clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
            margin-right: 25px;
            box-shadow: 0 0 25px var(--rho-gold-glow);
            text-shadow: 0 1px 2px rgba(255,255,255,0.3);
            animation: shieldPulse 3s infinite;
        }

        @keyframes shieldPulse {
            0%, 100% { transform: scale(1); filter: brightness(1); }
            50% { transform: scale(1.05); filter: brightness(1.2); }
        }

        .title-container h1 {
            margin: 0;
            font-size: 1.8rem;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .title-container p {
            margin: 0;
            color: var(--rho-gold);
            font-size: 0.8rem;
            font-weight: bold;
            letter-spacing: 4px;
        }

        .live-dot {
            height: 12px; width: 12px; background-color: #ff0000;
            border-radius: 50%; display: inline-block; margin-left: 10px;
            box-shadow: 0 0 10px #ff0000;
            animation: blink 1.2s infinite;
        }

        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

        .main-layout { 
            display: grid; 
            grid-template-columns: 400px 1fr; 
            gap: 40px; 
            padding: 40px; 
            max-width: 1600px; 
            margin: auto; 
        }

        .panel {
            background: var(--card-bg);
            border: 1px solid rgba(201, 160, 90, 0.1);
            padding: 35px;
            border-radius: 20px;
            backdrop-filter: blur(20px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        h2 { 
            font-size: 0.9rem; 
            letter-spacing: 5px; 
            color: var(--rho-gold); 
            margin-bottom: 25px; 
            text-transform: uppercase;
            border-bottom: 1px solid rgba(201, 160, 90, 0.2);
            padding-bottom: 10px;
        }

        .entry-fields { display: flex; flex-direction: column; gap: 15px; margin-bottom: 30px; }
        input { 
            background: rgba(0,0,0,0.5); 
            border: 1px solid #333; 
            color: white; 
            padding: 15px; 
            border-radius: 10px; 
            font-size: 1rem;
            transition: 0.3s;
        }
        input:focus { border-color: var(--rho-gold); outline: none; box-shadow: 0 0 10px var(--rho-gold-glow); }

        button { cursor: pointer; border-radius: 10px; border: none; font-weight: 800; text-transform: uppercase; transition: 0.3s; }

        .primary-action { 
            background: var(--rho-gold); 
            color: black; 
            width: 100%; 
            padding: 18px; 
            font-size: 1.2rem; 
            margin-top: 20px; 
        }
        .primary-action:hover { background: #e0b46a; box-shadow: 0 0 30px var(--rho-gold-glow); transform: translateY(-2px); }

        #addBtn { background: #222; color: white; padding: 12px; border: 1px solid #444; }
        #addBtn:hover { background: #333; border-color: var(--rho-gold); }

        .secondary-action { background: transparent; color: #555; border: 1px solid #222; width: 100%; margin-top: 15px; padding: 10px; }
        .secondary-action:hover { color: #888; border-color: #444; }

        .result-item {
            background: #0a0e14;
            padding: 25px;
            border-radius: 15px;
            border: 1px solid #1a1f26;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 900;
            margin-bottom: 15px;
            cursor: pointer;
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .result-item:hover:not(.revealed) { border-color: var(--neon-cyan); transform: translateX(10px); }

        .reveal-text { color: var(--neon-cyan); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }

        .result-item.revealed {
            background: rgba(255, 255, 255, 0.05);
            animation: revealFlip 0.6s ease forwards;
            cursor: default;
        }

        .result-item.revealed[data-pick="1"] {
            border: 2px solid var(--rho-gold);
            box-shadow: 0 0 50px var(--rho-gold-glow);
            transform: scale(1.08);
        }

        .team-name { display: none; font-size: 1.8rem; letter-spacing: 1px; }
        .result-item.revealed .team-name { display: block; }
        .result-item.revealed .reveal-text, .result-item.revealed .pick-label { display: none; }

        @keyframes revealFlip {
            0% { transform: perspective(1000px) rotateX(-90deg); opacity: 0; }
            100% { transform: perspective(1000px) rotateX(0deg); opacity: 1; }
        }

        .ice-placeholder { text-align: center; color: #444; margin-top: 100px; font-weight: bold; letter-spacing: 2px; }

        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; color: #555; font-size: 0.7rem; padding-bottom: 10px; text-transform: uppercase; }
        td { border-bottom: 1px solid #1a1f26; padding: 12px 0; }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #030508; }
        ::-webkit-scrollbar-thumb { background: #222; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--rho-gold); }
    </style>
</head>
<body>
    <header>
        <div class="rho-shield">RHO</div>
        <div class="title-container">
            <h1>ULTRA-GLOW LOTTERY <span class="live-dot"></span></h1>
            <p>OFFICIAL RHO BROADCAST CENTER</p>
        </div>
    </header>

    <main class="main-layout">
        <section class="panel control-panel">
            <h2>COMMISSIONER TOOLS</h2>
            <div class="entry-fields">
                <input type="text" id="teamInput" placeholder="TEAM NAME (e.g. CANES)">
                <input type="number" id="oddsInput" placeholder="PROBABILITY %">
                <button id="addBtn">ENROLL TEAM</button>
            </div>
            <div style="max-height: 300px; overflow-y: auto; margin-bottom: 20px;">
                <table>
                    <thead>
                        <tr><th>TEAM ENTRIES</th><th>ODDS</th><th></th></tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
            </div>
            <button id="simBtn" class="primary-action">EXECUTE DRAW</button>
            <button id="resetBtn" class="secondary-action">PURGE DATABASE</button>
        </section>

        <section class="panel results-panel">
            <h2>DRAFT SEQUENCE REVEAL</h2>
            <div id="resultsList" class="results-container">
                <div class="ice-placeholder">SYSTEM STANDBY: ENTER TEAM DATA</div>
            </div>
        </section>
    </main>

    <script>
        const rhoTeams = {
            "DUCKS": "#F47A38", "BRUINS": "#FFB81C", "SABRES": "#002654",
            "FLAMES": "#C8102E", "CANES": "#CC0000", "HURRICANES": "#CC0000",
            "BLACKHAWKS": "#CF0A2C", "AVALANCHE": "#6F263D", "BLUE JACKETS": "#002654",
            "STARS": "#006439", "RED WINGS": "#CE1126", "EDMONTON": "#041E42",
            "PANTHERS": "#041E42", "KINGS": "#111111", "WILD": "#154734",
            "CANADIENS": "#AF1E2D", "PREDATORS": "#FFB81C", "DEVILS": "#CE1126",
            "ISLANDERS": "#00539B", "RANGERS": "#0038A8", "SENATORS": "#C52032",
            "FLYERS": "#F74902", "PENGUINS": "#FCB514", "SHARKS": "#006D75",
            "KRAKEN": "#001628", "BLUES": "#002F87", "LIGHTNING": "#002868",
            "MAPLE LEAFS": "#00205B", "CANUCKS": "#00205B", "GOLDEN KNIGHTS": "#B4975A",
            "CAPITALS": "#041E42", "JETS": "#004C97", "UTAH": "#6CBEEB", "DEFAULT": "#c9a05a"
        };

        let teams = [];

        document.getElementById('addBtn').addEventListener('click', () => {
            const name = document.getElementById('teamInput').value.trim().toUpperCase();
            const odds = parseFloat(document.getElementById('oddsInput').value);
            if (!name || isNaN(odds)) return;
            teams.push({ name, odds });
            renderTable();
            document.getElementById('teamInput').value = "";
            document.getElementById('oddsInput').value = "";
        });

        function renderTable() {
            const body = document.getElementById('tableBody');
            body.innerHTML = teams.map((t, i) => `
                <tr><td style="color:white; font-weight:900; font-size:1.1rem;">${t.name}</td>
                <td style="color:var(--neon-cyan); font-weight:bold;">${t.odds}%</td>
                <td style="text-align:right;"><button onclick="removeTeam(${i})" style="color:#ff4444; background:none; font-size:14px;">✕</button></td></tr>
            `).join('');
        }

        function removeTeam(i) { teams.splice(i, 1); renderTable(); }

        document.getElementById('simBtn').addEventListener('click', () => {
            if (teams.length === 0) return;
            const results = document.getElementById('resultsList');
            results.innerHTML = "";
            
            let drawPool = JSON.parse(JSON.stringify(teams));
            let finalOrder = [];

            // Weighted random selection
            while (drawPool.length > 0) {
                let totalOdds = drawPool.reduce((sum, t) => sum + t.odds, 0);
                let random = Math.random() * totalOdds;
                let currentSum = 0;
                
                for (let i = 0; i < drawPool.length; i++) {
                    currentSum += drawPool[i].odds;
                    if (random <= currentSum) {
                        finalOrder.push(drawPool.splice(i, 1)[0]);
                        break;
                    }
                }
            }

            // Display from last pick to first for suspense
            finalOrder.reverse().forEach((t, i) => {
                const pickNumber = finalOrder.length - i;
                const color = rhoTeams[t.name] || rhoTeams["DEFAULT"];
                const item = document.createElement('div');
                item.className = 'result-item';
                item.setAttribute('data-pick', pickNumber);
                item.innerHTML = `
                    <span class="pick-label" style="color:#555;">PICK #${pickNumber}</span>
                    <span class="reveal-text">CLICK TO REVEAL</span>
                    <span class="team-name" style="color:${color}; text-shadow: 0 0 20px ${color}88">#${pickNumber} ${t.name}</span>
                `;
                item.addEventListener('click', function() {
                    if (!this.classList.contains('revealed')) {
                        this.classList.add('revealed');
                        this.style.borderLeft = `10px solid ${color}`;
                        this.style.background = `linear-gradient(90deg, rgba(0,0,0,0.8), ${color}20)`;
                    }
                });
                results.appendChild(item);
            });
        });

        document.getElementById('resetBtn').addEventListener('click', () => {
            if(confirm("Confirm system purge? All team data will be erased.")) {
                location.reload();
            }
        });
    </script>
</body>
</html>
